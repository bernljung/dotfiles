#!/usr/bin/env zsh
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Create the user-owned directories referenced by .zshrc and the linked configs.
mkdir -p \
  "$HOME/.config/ghostty" \
  "$HOME/.config/helix" \
  "$HOME/.dotnet" \
  "$HOME/.dotnet/tools" \
  "$HOME/go" \
  "$HOME/go/bin" \
  "$HOME/Library/Application Support/lazygit" \
  "$HOME/Library/Python/3.11/bin"

# Link the tracked shell, Ghostty, Helix, and Lazygit configs into the home directory.
ln -sfn "$REPO_ROOT/.zshrc" "$HOME/.zshrc"
ln -sfn "$REPO_ROOT/.config/ghostty/config" "$HOME/.config/ghostty/config"
ln -sfn "$REPO_ROOT/.config/helix/config.toml" "$HOME/.config/helix/config.toml"
ln -sfn "$REPO_ROOT/.config/helix/languages.toml" "$HOME/.config/helix/languages.toml"
ln -sfn "$REPO_ROOT/Library/Application Support/lazygit/config.yml" "$HOME/Library/Application Support/lazygit/config.yml"

echo "Linked .zshrc -> $HOME/.zshrc"
echo "Linked Ghostty config -> $HOME/.config/ghostty/config"
echo "Linked Helix config -> $HOME/.config/helix/config.toml"
echo "Linked Helix languages -> $HOME/.config/helix/languages.toml"
echo "Linked Lazygit config -> $HOME/Library/Application Support/lazygit/config.yml"

# Install Homebrew if it is not already available.
if ! command -v brew >/dev/null 2>&1; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Re-resolve Homebrew after install in case the shell PATH has not been reloaded yet.
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Install Git, Helix, Lazygit, and wget from Homebrew if any are not already available.
if ! command -v git >/dev/null 2>&1 || ! command -v hx >/dev/null 2>&1 || ! command -v lazygit >/dev/null 2>&1 || ! command -v wget >/dev/null 2>&1; then
  brew install git helix lazygit wget
fi

# Install .NET SDK 8 and 10 into ~/.dotnet using Microsoft's install script.
DOTNET_BIN="$HOME/.dotnet/dotnet"
dotnet_sdk_installed() {
  local major="$1"
  [[ -x "$DOTNET_BIN" ]] && "$DOTNET_BIN" --list-sdks | awk '{ print $1 }' | grep -q "^${major}\."
}

if ! dotnet_sdk_installed 8 || ! dotnet_sdk_installed 10; then
  mkdir -p "$HOME/Downloads"
  (
    cd "$HOME/Downloads"
    wget -O dotnet-install.sh https://dot.net/v1/dotnet-install.sh
    chmod +x dotnet-install.sh

    if ! dotnet_sdk_installed 8; then
      ./dotnet-install.sh --channel 8.0 --install-dir "$HOME/.dotnet"
    fi

    if ! dotnet_sdk_installed 10; then
      ./dotnet-install.sh --channel 10.0 --install-dir "$HOME/.dotnet"
    fi
  )
fi

# Install Pi if it is not already available on this machine.
if ! command -v pi >/dev/null 2>&1; then
  curl -fsSL https://pi.dev/install.sh | bash
fi

# Re-resolve the Pi binary after install in case the shell PATH has not been reloaded yet.
PI_BIN="$(command -v pi || true)"
if [[ -z "$PI_BIN" && -x "$HOME/.local/bin/pi" ]]; then
  PI_BIN="$HOME/.local/bin/pi"
fi

# Install the ANSI themes package once Pi is available.
if [[ -n "$PI_BIN" ]]; then
  "$PI_BIN" install git:github.com/leblancfg/pi-ansi-themes
else
  echo "Warning: pi was not found after installation; skipped pi-ansi-themes install." >&2
fi

if [[ ! -f "$HOME/.zshrc.local" ]]; then
  echo "Tip: create $HOME/.zshrc.local from $REPO_ROOT/.zshrc.local.example for secrets and machine-local overrides."
fi
