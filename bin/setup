#!/usr/bin/env zsh
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DOTNET_BIN="$HOME/.dotnet/dotnet"

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

link_file() {
  local source="$1"
  local target="$2"

  ln -sfn "$source" "$target"
  echo "Linked $target -> $source"
}

dotnet_sdk_installed() {
  local major="$1"
  [[ -x "$DOTNET_BIN" ]] && "$DOTNET_BIN" --list-sdks | awk '{ print $1 }' | grep -q "^${major}\\."
}

# Create the user-owned directories referenced by .zshrc and the linked configs.
mkdir -p \
  "$HOME/.config/ghostty" \
  "$HOME/.config/helix" \
  "$HOME/.dotnet" \
  "$HOME/.dotnet/tools" \
  "$HOME/.opencode/bin" \
  "$HOME/.pi/agent" \
  "$HOME/.pi/skills/grill-me" \
  "$HOME/go" \
  "$HOME/go/bin" \
  "$HOME/Downloads" \
  "$HOME/Library/Application Support/lazygit" \
  "$HOME/Library/Python/3.11/bin"

# Link tracked configs into place.
link_file "$REPO_ROOT/.zshrc" "$HOME/.zshrc"
link_file "$REPO_ROOT/.dprint.json" "$HOME/.dprint.json"
link_file "$REPO_ROOT/.config/ghostty/config" "$HOME/.config/ghostty/config"
link_file "$REPO_ROOT/.config/helix/config.toml" "$HOME/.config/helix/config.toml"
link_file "$REPO_ROOT/.config/helix/languages.toml" "$HOME/.config/helix/languages.toml"
link_file "$REPO_ROOT/.pi/agent/AGENTS.md" "$HOME/.pi/agent/AGENTS.md"
link_file "$REPO_ROOT/.pi/agent/settings.json" "$HOME/.pi/agent/settings.json"
link_file "$REPO_ROOT/.pi/agent/models.json" "$HOME/.pi/agent/models.json"
link_file "$REPO_ROOT/.pi/skills/grill-me/SKILL.md" "$HOME/.pi/skills/grill-me/SKILL.md"
link_file "$REPO_ROOT/Library/Application Support/lazygit/config.yml" "$HOME/Library/Application Support/lazygit/config.yml"

# Link Ghostty themes.
mkdir -p "$HOME/.config/ghostty/themes"
for theme in "$REPO_ROOT/themes/ghostty/"*; do
  name="$(basename "$theme")"
  ln -sfn "$theme" "$HOME/.config/ghostty/themes/$name"
  echo "Linked $HOME/.config/ghostty/themes/$name -> $theme"
done

# Install Homebrew if it is not already available.
if ! have_cmd brew; then
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

# Re-resolve Homebrew after install in case the shell PATH has not been reloaded yet.
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# Install required Homebrew packages.
typeset -a missing_brew_packages=()
have_cmd colima || missing_brew_packages+=(colima)
have_cmd dprint || missing_brew_packages+=(dprint)
have_cmd git || missing_brew_packages+=(git)
have_cmd gofumpt || missing_brew_packages+=(gofumpt)
have_cmd hx || missing_brew_packages+=(helix)
have_cmd lazygit || missing_brew_packages+=(lazygit)
have_cmd marksman || missing_brew_packages+=(marksman)
have_cmd prettier || missing_brew_packages+=(prettier)
have_cmd shfmt || missing_brew_packages+=(shfmt)
have_cmd sql-formatter || missing_brew_packages+=(sql-formatter)
have_cmd swift-format || missing_brew_packages+=(swift-format)
have_cmd wget || missing_brew_packages+=(wget)

if (( ${#missing_brew_packages[@]} > 0 )); then
  brew install "${missing_brew_packages[@]}"
fi

# Install .NET SDK 8 and 10 into ~/.dotnet using Microsoft's install script.
if ! dotnet_sdk_installed 8 || ! dotnet_sdk_installed 10; then
  (
    cd "$HOME/Downloads"
    wget -O dotnet-install.sh https://dot.net/v1/dotnet-install.sh
    chmod +x dotnet-install.sh

    if ! dotnet_sdk_installed 8; then
      ./dotnet-install.sh --channel 8.0 --install-dir "$HOME/.dotnet"
    fi

    if ! dotnet_sdk_installed 10; then
      ./dotnet-install.sh --channel 10.0 --install-dir "$HOME/.dotnet"
    fi
  )
fi

# Install Pi if it is not already available on this machine.
if ! have_cmd pi; then
  curl -fsSL https://pi.dev/install.sh | bash
fi

# Re-resolve the Pi binary after install in case the shell PATH has not been reloaded yet.
PI_BIN="$(command -v pi || true)"
if [[ -z "$PI_BIN" && -x "$HOME/.local/bin/pi" ]]; then
  PI_BIN="$HOME/.local/bin/pi"
fi

# Install the ANSI themes package once Pi is available.
if [[ -n "$PI_BIN" ]]; then
  "$PI_BIN" install git:github.com/leblancfg/pi-ansi-themes
else
  echo "Warning: pi was not found after installation; skipped pi-ansi-themes install." >&2
fi

if [[ ! -f "$HOME/.zshrc.local" ]]; then
  echo "Tip: create $HOME/.zshrc.local from $REPO_ROOT/.zshrc.local.example for secrets and machine-local overrides."
fi
